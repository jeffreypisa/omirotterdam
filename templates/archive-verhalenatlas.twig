{% extends "base.twig" %}

{% block content %}
<article class="post-type-{{ post.post_type }}" id="post-{{ post.ID }}">
	<section class="mod-content bg-blue text-white" data-scroll-section>
		{% if is_verhalenatlas_tax %}
			<div class="container text-start">
				<div class="row">
					<div class="col-12">
						<h1 class="h2 mt-3 mb-3 text-center">
							Verhalenatlas
						</h1>
					</div>
				</div>
			</div>
		{% else %}
			<div class="container text-start text-md-center">
				<div class="row">
					<div class="col-md-10 offset-md-1">
					<h1 class="h2 mb-2 mt-3">
						{% if lang == 'nl_NL' %}Verhalenatlas{% else %}Story Atlas{% endif %}
					</h1>
					{% if post.subtitel %}
						<h3 class="mb-3 mb-md-4 weight-400">{{ post.subtitel }}</h3>
					{% endif %}

					<div class="verhalenatlas-actions verhalenatlas-header-controls mb-2">
						{% if verhalenatlas_archive_category_link %}
							<a href="#verhalenatlas-gebieden" class="btn btn-light me-2 mb-2">
								{% if lang == 'nl_NL' %}Bekijk gebieden{% else %}View areas{% endif %}
							</a>
						{% endif %}
						{% if verhalenatlas_all_verhalen_link %}
							<a href="{{ verhalenatlas_all_verhalen_link }}" class="btn btn-light mb-2">
								{% if lang == 'nl_NL' %}Bekijk routes{% else %}View routes{% endif %}
							</a>
						{% endif %}
					</div>
					</div>
				</div>
			</div>
		{% endif %}
	</section>

	{% if is_verhalenatlas_tax %}
		<section class="mod-archive bg-greylight" data-scroll-section>
			<div class="container">
				<div class="verhalenatlas-toolbar mb-3">
					<div class="verhalenatlas-category-controls verhalenatlas-header-controls">
						<div class="verhalenatlas-category-left form-group mb-0">
							<form id="category-select" class="category-dropdown" action="{{ currenturl }}" method="get">
								<select class="form-select" name="verhalenatlas_category" id="verhalenatlas-category" onchange="if(this.value){window.location.href=this.value;}">
									{% for category in categories %}
										<option value="{{ category.link }}" {% if current_category == category.term_id %}selected{% endif %}>
											{{ category.title }}
										</option>
									{% endfor %}
								</select>
							</form>
						</div>
						{% if is_verhalenatlas_all_routes_page and verhalenatlas_filters %}
							<div class="verhalenatlas-category-right">
								{% set filter_base_link = verhalenatlas_current_term_link ?: (currenturl|split('?')|first) %}
								<div class="verhalenatlas-filter-dropdown">
									<form class="category-dropdown" action="{{ currenturl }}" method="get">
										<select class="form-select" name="filter" onchange="if(this.value==='__all__'){window.location.href='{{ filter_base_link }}';}else{window.location.href='{{ filter_base_link }}?filter='+this.value;}">
											<option value="__all__" {% if selected_filter == '' %}selected{% endif %}>
												{% if lang == 'nl_NL' %}Filter{% else %}Filter{% endif %}
											</option>
											{% for item in verhalenatlas_filters %}
												<option value="{{ item.slug }}" {% if selected_filter == item.slug %}selected{% endif %}>
													{{ item.title }}
												</option>
											{% endfor %}
										</select>
									</form>
								</div>
								{% if posts|length > 0 %}
									<div class="verhalenatlas-filter-buttons">
										<a href="{{ filter_base_link }}" class="btn {% if selected_filter == '' %}btn-dark{% else %}btn-outline-dark{% endif %} mb-2">
											{% if lang == 'nl_NL' %}Alle{% else %}All{% endif %}
										</a>
										{% for item in verhalenatlas_filters %}
											<a href="{{ filter_base_link }}?filter={{ item.slug }}" class="btn {% if selected_filter == item.slug %}btn-dark{% else %}btn-outline-dark{% endif %} mb-2">
												{{ item.title }}
											</a>
										{% endfor %}
									</div>
								{% endif %}
							</div>
						{% endif %}
					</div>
				</div>
				{% if posts|length %}
					<div class="row mt-4 anime-fadein">
						{% for item in posts %}
						<div class="col-md-6">
							{% include ['tease-verhalenatlas.twig'] %}
						</div>
						{% endfor %}
					</div>
				{% else %}
					<div class="row mt-4">
						<div class="col-12 text-center">
							<p class="lead mb-0">
								{% if selected_filter %}
									{% if lang == 'nl_NL' %}Geen routes beschikbaar voor dit filter.{% else %}No routes available for this filter.{% endif %}
								{% else %}
									{% if lang == 'nl_NL' %}Geen routes beschikbaar.{% else %}No routes available.{% endif %}
								{% endif %}
							</p>
						</div>
					</div>
				{% endif %}

				{% if verhalenatlas_routes_posts %}
					<div class="verhalenatlas-routes-strook mt-5 pt-2" id="verhalenatlas-routes">
						<h2 class="h2 mb-4">{{ verhalenatlas_routes_title }}</h2>
						<div class="row anime-fadein">
							{% for item in verhalenatlas_routes_posts %}
							<div class="col-md-6 col-lg-4">
								{% include ['tease-verhalenatlas.twig'] %}
							</div>
							{% endfor %}
						</div>
						{% if verhalenatlas_routes_overview_link %}
							<a href="{{ verhalenatlas_routes_overview_link }}" class="btn btn-light mt-3">
								{{ verhalenatlas_routes_overview_label }}
							</a>
						{% endif %}
					</div>
				{% endif %}
				{% include 'partial/pagination.twig' with { pagination: posts.pagination({show_all: false, mid_size: 3, end_size: 2}) } %}
			</div>
		</section>
	{% else %}
		<section class="mod-archive bg-greylight" data-scroll-section>
			<div class="container">
				{% if options.verhalenatlas_intro_content or options.verhalenatlas_intro_image %}
					<div class="row align-items-center verhalenatlas-intro mb-0">
						<div class="col-lg-7 mb-4 mb-lg-0">
							<h2 class="mb-3">
								{{ options.verhalenatlas_intro_title ?: ((lang == 'nl_NL') ? 'Introductie' : 'Introduction') }}
							</h2>
							<div class="content">
								{{ options.verhalenatlas_intro_content }}
							</div>
						</div>
						<div class="col-lg-5">
							{% if options.verhalenatlas_intro_image %}
								<div class="verhalenatlas-intro-image ratio-16x9 bg-cover" style="background-image: url({{ Image(options.verhalenatlas_intro_image).src|resize(1280) }})"></div>
							{% endif %}
						</div>
					</div>
				{% endif %}
			</div>
		</section>

		<section id="verhalenatlas-gebieden" class="mod-archive bg-white" data-scroll-section>
			<div class="container">
				<h2 class="h2 mb-4 mt-2">{{ verhalenatlas_grid_title }}</h2>

				<div class="row mt-2 anime-fadein verhalenatlas-grid">
					{% for item in posts %}
					<div class="col-md-6 col-lg-4">
						{% include ['tease-verhalenatlas.twig'] %}
					</div>
					{% endfor %}
				</div>
				{% include 'partial/pagination.twig' with { pagination: posts.pagination({show_all: false, mid_size: 3, end_size: 2}) } %}
			</div>
		</section>
	{% endif %}
	{% include 'pagebuilder.twig' %}
</article>
{% endblock %}
