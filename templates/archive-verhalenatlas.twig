{% extends "base.twig" %}

{% block content %}
<article class="post-type-{{ post.post_type }}" id="post-{{ post.ID }}">
	{% set hero_subtitle = post.subtitel ?: options.verhalenatlas_hero_subtitle %}
	{% if lang != 'nl_NL' and not post.subtitel and not options.verhalenatlas_hero_subtitle %}
		{% set hero_subtitle = options.verhalenatlas_hero_subtitle_en %}
	{% endif %}
	{% set label_gebieden = verhalenatlas_archive_button_label ?: ((lang == 'nl_NL') ? 'Alle gebieden' : 'All areas') %}
	{% set label_verhalen = verhalenatlas_all_verhalen_button_label ?: ((lang == 'nl_NL') ? 'Alle verhalen' : 'All stories') %}
	{% set filter_base_link = verhalenatlas_current_term_link ?: (currenturl|split('?')|first) %}
	<section class="mod-content bg-blue text-white" data-scroll-section>
		{% if is_verhalenatlas_tax %}
			<div class="container text-start">
				<div class="row">
					<div class="col-12">
						<h1 class="h2 mt-3 mb-3 text-center">
							Verhalenatlas
						</h1>
						{% if is_verhalenatlas_all_routes_page and verhalenatlas_filters %}
							<div class="verhalenatlas-type-tabs">
								{% set area_query_suffix = selected_area ? '&gebied=' ~ selected_area : '' %}
								<a href="{{ filter_base_link }}{{ selected_area ? '?gebied=' ~ selected_area : '' }}" class="btn {% if selected_filter == '' %}btn-light{% else %}btn-outline-light{% endif %} mb-2">
									{{ label_verhalen }}
								</a>
								{% for item in verhalenatlas_filters %}
									<a href="{{ filter_base_link }}?filter={{ item.slug }}{{ area_query_suffix }}" class="btn {% if selected_filter == item.slug %}btn-light{% else %}btn-outline-light{% endif %} mb-2">
										{{ item.title }}
									</a>
								{% endfor %}
							</div>
						{% endif %}
					</div>
				</div>
			</div>
		{% else %}
			<div class="container text-start text-md-center">
				<div class="row">
					<div class="col-md-10 offset-md-1">
					<h1 class="h2 mb-2 mt-3 text-center">
						{% if lang == 'nl_NL' %}Verhalenatlas{% else %}Story Atlas{% endif %}
					</h1>
					{% if hero_subtitle %}
						<h3 class="mb-3 mb-md-4 weight-400">{{ hero_subtitle }}</h3>
					{% endif %}

					<div class="verhalenatlas-actions verhalenatlas-actions--dual verhalenatlas-header-controls mb-2">
						{% if verhalenatlas_archive_category_link %}
							<a href="#verhalenatlas-gebieden" class="btn btn-light me-2 mb-2">
								{{ label_gebieden }}
							</a>
						{% endif %}
						{% if verhalenatlas_all_verhalen_link %}
							<a href="{{ verhalenatlas_all_verhalen_link }}" class="btn btn-light mb-2">
								{{ label_verhalen }}
							</a>
						{% endif %}
					</div>
					</div>
				</div>
			</div>
		{% endif %}
	</section>

	{% if is_verhalenatlas_tax %}
		<section class="mod-archive bg-greylight" data-scroll-section>
			<div class="container">
				<div class="verhalenatlas-toolbar mb-3">
					{% if is_verhalenatlas_all_routes_page %}
						{% if verhalenatlas_area_filters %}
							<div class="verhalenatlas-area-filter-wrap">
								<form class="verhalenatlas-area-filter" action="{{ filter_base_link }}" method="get">
									{% if selected_filter %}
										<input type="hidden" name="filter" value="{{ selected_filter }}">
									{% endif %}
									<select class="form-select" name="gebied" onchange="this.form.submit()">
										<option value="" {% if selected_area == '' %}selected{% endif %}>
											{% if lang == 'nl_NL' %}Alle gebieden{% else %}All areas{% endif %}
										</option>
										{% for gebied in verhalenatlas_area_filters %}
											<option value="{{ gebied.slug }}" {% if selected_area == gebied.slug %}selected{% endif %}>
												{{ gebied.title }}
											</option>
										{% endfor %}
									</select>
								</form>
							</div>
						{% endif %}
					{% else %}
						<div class="verhalenatlas-category-controls verhalenatlas-header-controls">
							<div class="verhalenatlas-category-left form-group mb-0">
								<form id="category-select" class="category-dropdown" action="{{ currenturl }}" method="get">
									<select class="form-select" name="verhalenatlas_category" id="verhalenatlas-category" onchange="if(this.value){window.location.href=this.value;}">
										{% for category in categories %}
											<option value="{{ category.link }}" {% if current_category == category.term_id %}selected{% endif %}>
												{{ category.title }}
											</option>
										{% endfor %}
									</select>
								</form>
							</div>
						</div>
					{% endif %}
				</div>
				{% if posts|length %}
					<div class="row mt-4 anime-fadein">
						{% for item in posts %}
						<div class="col-md-6">
							{% include ['tease-verhalenatlas.twig'] %}
						</div>
						{% endfor %}
					</div>
				{% else %}
					<div class="row mt-4">
						<div class="col-12 text-center">
							<p class="lead mb-0">
								{% if selected_filter %}
									{% if lang == 'nl_NL' %}Geen routes beschikbaar voor dit filter.{% else %}No routes available for this filter.{% endif %}
								{% else %}
									{% if lang == 'nl_NL' %}Geen routes beschikbaar.{% else %}No routes available.{% endif %}
								{% endif %}
							</p>
						</div>
					</div>
				{% endif %}

				{% if verhalenatlas_routes_posts %}
					<div class="verhalenatlas-routes-strook mt-5 pt-2" id="verhalenatlas-routes">
						<h2 class="h2 mb-4">{{ verhalenatlas_routes_title }}</h2>
						<div class="row anime-fadein">
							{% for item in verhalenatlas_routes_posts %}
							<div class="col-md-6 col-lg-4">
								{% include ['tease-verhalenatlas.twig'] %}
							</div>
							{% endfor %}
						</div>
						{% if verhalenatlas_routes_overview_link %}
							<a href="{{ verhalenatlas_routes_overview_link }}" class="btn btn-light mt-3">
								{{ verhalenatlas_routes_overview_label }}
							</a>
						{% endif %}
					</div>
				{% endif %}
				{% include 'partial/pagination.twig' with { pagination: posts.pagination({show_all: false, mid_size: 3, end_size: 2}) } %}
			</div>
		</section>
	{% else %}
		<section class="mod-archive bg-greylight" data-scroll-section>
			<div class="container">
				{% set intro_image = options.verhalenatlas_intro_image ? Image(options.verhalenatlas_intro_image) : null %}
				{% set intro_image_src = intro_image and intro_image.src ? intro_image.src|resize(1280) : '' %}
				{% if not intro_image_src and options.verhalenatlas_intro_image.url %}
					{% set intro_image_src = options.verhalenatlas_intro_image.url %}
				{% endif %}
				{% if not intro_image_src and options.verhalenatlas_intro_image is iterable and options.verhalenatlas_intro_image.ID %}
					{% set intro_image_src = Image(options.verhalenatlas_intro_image.ID).src|resize(1280) %}
				{% endif %}
				{% if not intro_image_src and options.verhalenatlas_intro_image is not iterable and options.verhalenatlas_intro_image %}
					{% set intro_image_src = options.verhalenatlas_intro_image %}
				{% endif %}

				{% if options.verhalenatlas_intro_content or intro_image_src %}
					<div class="row align-items-stretch verhalenatlas-intro mb-0">
						<div class="col-lg-7 mb-4 mb-lg-0">
							<div class="verhalenatlas-intro-panel verhalenatlas-intro-text">
								<h2 class="mb-3">
									{{ options.verhalenatlas_intro_title ?: ((lang == 'nl_NL') ? 'Introductie' : 'Introduction') }}
								</h2>
								<div class="content">
									{{ options.verhalenatlas_intro_content }}
								</div>
							</div>
						</div>
						<div class="col-lg-5">
							{% if intro_image_src %}
								<div class="verhalenatlas-intro-panel verhalenatlas-intro-image-wrap">
									<div class="verhalenatlas-intro-image ratio-16x9 bg-cover w-100" style="background-image: url('{{ intro_image_src }}')"></div>
								</div>
							{% endif %}
						</div>
					</div>
				{% endif %}
			</div>
		</section>

		<section id="verhalenatlas-gebieden" class="mod-archive bg-blue text-white" data-scroll-section>
			<div class="container">
				<h2 class="h2 mb-4 mt-2 text-center weight-700">{{ verhalenatlas_grid_title }}</h2>

				<div class="row mt-2 anime-fadein verhalenatlas-grid">
					{% for item in posts %}
					<div class="col-md-6 col-lg-4">
						{% include ['tease-verhalenatlas.twig'] %}
					</div>
					{% endfor %}
				</div>
				{% set gebieden_section_button = options.verhalenatlas_gebieden_button_link ?: options.verhalenatlas_archive_page_link %}
				{% set gebieden_section_label = options.verhalenatlas_gebieden_button_label ?: options.verhalenatlas_archive_button_label %}
				{% if lang != 'nl_NL' and not gebieden_section_label %}
					{% set gebieden_section_label = options.verhalenatlas_gebieden_button_label_en ?: options.verhalenatlas_archive_button_label_en %}
				{% endif %}
				{% if gebieden_section_button and gebieden_section_button.url %}
					<div class="text-center mt-4">
						<a href="{{ gebieden_section_button.url }}" {% if gebieden_section_button.target %}target="{{ gebieden_section_button.target }}"{% endif %} class="btn btn-light">
							{{ gebieden_section_label ?: ((lang == 'nl_NL') ? 'Meer gebieden' : 'More areas') }}
						</a>
					</div>
				{% endif %}
				{% include 'partial/pagination.twig' with { pagination: posts.pagination({show_all: false, mid_size: 3, end_size: 2}) } %}
			</div>
		</section>
	{% endif %}
	{% include 'pagebuilder.twig' %}
</article>
{% endblock %}
