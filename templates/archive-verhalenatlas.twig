{% extends "base.twig" %}

{% block content %}
<article class="post-type-{{ post.post_type }}" id="post-{{ post.ID }}">
	<section class="mod-archive bg-greylight" data-scroll-section>
		<div class="container">
			<h1 class="h2 mb-2 mt-3 text-center">
				{% if lang == 'nl_NL' %}Verhalenatlas{% else %}Story Atlas{% endif %}
			</h1>
			{% if categories %}
			<div class="mod-categories mb-5">
				<div class="container text-center">
					<a href="{{ site.url }}/{% if lang == 'nl_NL' %}verhalenatlas/{% else %}en/verhalenatlas/{% endif %}" class="{% if current_category == '' %}active{% endif %}">
						{% if lang == 'nl_NL' %}alle{% else %}all{% endif %}
					</a>
					{% for item in categories %}
					<span> | </span> 
					<a href="{{ item.link }}" class="{% if item.id == current_category %}active{% endif %}">{{ item.title|lower }}</a>
					{% endfor %}
				</div>
			</div>
			{% endif %}
			<div class="row mt-2 anime-fadein">
				{% for item in posts %}
				<div class="col-md-6">
					{% include ['tease-verhalenatlas.twig'] %}
				</div>
				{% endfor %}
			</div>
			{% include 'partial/pagination.twig' with { pagination: posts.pagination({show_all: false, mid_size: 3, end_size: 2}) } %}
		</div>
	</section>
	{% include 'pagebuilder.twig' %}
</article>
{% endblock %}